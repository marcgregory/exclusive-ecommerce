PORT=4000
WEB_ORIGIN=http://127.0.0.1:5173
# Production may use WEB_ORIGINS for a comma-separated allowlist.
# WEB_ORIGINS=https://exclusive.example.com,https://exclusive-git-main.vercel.app
SESSION_SECRET=replace-me-with-at-least-32-characters
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/exclusive_ecommerce

# Payments
# PAYMENT_PROVIDER=local keeps the development/test payment simulator.
# Set PAYMENT_PROVIDER=stripe and STRIPE_SECRET_KEY for Stripe PaymentIntents.
PAYMENT_PROVIDER=local
# STRIPE_SECRET_KEY=sk_test_replace_me
# STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_CURRENCY=usd
STRIPE_AMOUNT_MULTIPLIER=100
