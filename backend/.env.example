PORT=4000
WEB_ORIGIN=http://127.0.0.1:5173
# Production may use WEB_ORIGINS for a comma-separated allowlist.
# WEB_ORIGINS=https://exclusive.example.com,https://exclusive-git-main.vercel.app
SESSION_SECRET=replace-me-with-at-least-32-characters
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/exclusive_ecommerce

# Product image storage
# IMAGE_STORAGE_PROVIDER=local keeps uploads on disk under /uploads/product-images.
# Set IMAGE_STORAGE_PROVIDER=cloudinary with either CLOUDINARY_URL or the three credential fields.
IMAGE_STORAGE_PROVIDER=local
# CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
# CLOUDINARY_CLOUD_NAME=replace_me
# CLOUDINARY_API_KEY=replace_me
# CLOUDINARY_API_SECRET=replace_me

# Payments
# PAYMENT_PROVIDER=local keeps the development/test payment simulator.
# Set PAYMENT_PROVIDER=stripe and STRIPE_SECRET_KEY for Stripe PaymentIntents.
PAYMENT_PROVIDER=local
# STRIPE_SECRET_KEY=sk_test_replace_me
# STRIPE_WEBHOOK_SECRET=whsec_replace_me
# NODE_ENV=production
STRIPE_CURRENCY=php
STRIPE_AMOUNT_MULTIPLIER=100
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
RESEND_API_KEY=
CONTACT_TO_EMAIL=
